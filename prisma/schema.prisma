generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum Role {
  ADMIN
  MANAGER
  TECHNICIAN
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  WON
  LOST
}

enum LeadChannel {
  WEB_FORM
  PHONE
  EMAIL
  CHAT
  WHATSAPP
  FACEBOOK
  YELP
  GOOGLE_LSA
}

enum JobStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model Tenant {
  id        String   @id @default(cuid())
  name      String
  plan      String   @default("Professional")
  brandColor String  @default("#2563eb")
  createdAt DateTime @default(now())

  users     User[]
  leads     Lead[]
  customers Customer[]
  jobs      Job[]
  chatSessions ChatSession[]
}

model User {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  email     String   @unique
  name      String
  passwordHash String
  role      Role     @default(TECHNICIAN)
  createdAt DateTime @default(now())

  assignedJobs Job[] @relation("AssignedTechnician")
}

model Customer {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  name      String
  email     String?
  phone     String?
  address   String?
  createdAt DateTime @default(now())

  jobs      Job[]
  leads     Lead[]
}

model Lead {
  id          String      @id @default(cuid())
  tenantId    String
  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  customerId  String?
  customer    Customer?   @relation(fields: [customerId], references: [id])
  name        String
  email       String?
  phone       String?
  serviceType String?
  channel     LeadChannel @default(WEB_FORM)
  status      LeadStatus  @default(NEW)
  notes       String?
  createdAt   DateTime    @default(now())

  jobs        Job[]
}

model Job {
  id            String    @id @default(cuid())
  tenantId      String
  tenant        Tenant    @relation(fields: [tenantId], references: [id])
  leadId        String?
  lead          Lead?     @relation(fields: [leadId], references: [id])
  customerId    String
  customer      Customer  @relation(fields: [customerId], references: [id])
  technicianId  String?
  technician    User?     @relation("AssignedTechnician", fields: [technicianId], references: [id])
  title         String
  serviceType   String?
  status        JobStatus @default(SCHEDULED)
  scheduledAt   DateTime
  amount        Float?
  notes         String?
  createdAt     DateTime  @default(now())
}

model ChatSession {
  id               String   @id @default(cuid())
  tenantId         String
  tenant           Tenant   @relation(fields: [tenantId], references: [id])
  convertedLeadId  String?
  createdAt        DateTime @default(now())

  messages  ChatMessage[]
}

model ChatMessage {
  id            String      @id @default(cuid())
  chatSessionId String
  chatSession   ChatSession @relation(fields: [chatSessionId], references: [id])
  role          String
  content       String
  createdAt     DateTime    @default(now())
}
